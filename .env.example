BEGINNER_AGENT_MEMORY_BACKEND=postgres
DATABASE_URL=postgresql://beginner_agent:beginner_agent@127.0.0.1:55432/beginner_agent
BEGINNER_AGENT_CHECKPOINT_BACKEND=postgres
# Optional: use a different database for LangGraph checkpoint.
# If empty, checkpointing.py reuses DATABASE_URL.
#
# BEGINNER_AGENT_CHECKPOINT_DATABASE_URL=<postgres checkpoint database url>
BEGINNER_AGENT_EMBEDDING_PROVIDER=omlx
BEGINNER_AGENT_EMBEDDING_DIM=1024
OMLX_BASE_URL=http://127.0.0.1:8000/v1
OMLX_API_KEY=local-omlx-key
OMLX_EMBEDDING_MODEL=Qwen3-Embedding-8B-4bit-DWQ
OMLX_EMBEDDING_SEND_DIMENSIONS=true
# Memory governance
#
# 中文注释：
# ttl 类型记忆默认保留多少天。
# pinned / long_term 记忆不会使用这个 TTL。
#
# BEGINNER_AGENT_MEMORY_TTL_DAYS=30

# Memory Postgres migrations
#
# 中文注释：
# Postgres memory schema 现在由 memory_migrations.py 统一管理。
# 它提供：
# - schema version：知道数据库当前到哪个版本。
# - migration files/code：每次建表、加列、建索引都有版本。
# - rollback migration：可以回滚到指定版本。
# - index migration：索引变更不再散落在业务代码里。
# - backfill job：历史数据补齐默认治理字段。
#
# 本地开发默认允许 Store 自动 upgrade，方便你直接运行 agent。
# 生产环境通常设置为 false，由 CI/CD 或运维脚本显式执行 upgrade。
#
# 常用命令：
#
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py status
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py upgrade
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py backfill --limit 1000
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py rollback --target-version 3
#
# BEGINNER_AGENT_MEMORY_MIGRATION_AUTO_UPGRADE=true

# Memory quality / reranker governance
#
# 中文注释：
# 默认使用本地规则评分，保证离线可运行、结果可复现。
# 如果要更接近生产级，可以逐步打开：
# - LLM judge：让模型对 memory 质量做第二意见。
# - cross-encoder：让专用 reranker 模型判断 query-memory 是否匹配。
# - A/B bucket：比较 control / candidate reranker 表现。
#
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_ENABLED=false
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_BASE_URL=http://127.0.0.1:8000/v1
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_API_KEY=local-omlx-key
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_MODEL=Qwen3.6-27B-bf16
# BEGINNER_AGENT_MEMORY_CROSS_ENCODER_URL=
# BEGINNER_AGENT_MEMORY_RERANK_BUCKET=

# Memory Query API
#
# 中文注释：
# 这是只读 Admin API，用来查询 memory、audit、failure pattern、pinned memory 等。
# 推荐用下面的命令启动：
#
#   PYTHONPATH=.. uv run uvicorn beginner_agent.memory_api.app:app --host 127.0.0.1 --port 8770
#
# BEGINNER_AGENT_MEMORY_API_HOST=127.0.0.1
# BEGINNER_AGENT_MEMORY_API_PORT=8770
# BEGINNER_AGENT_MEMORY_API_ACTOR_ID=local-admin
#
# Memory API auth / RBAC / rate limit
#
# 中文注释：
# 本地默认 BEGINNER_AGENT_MEMORY_API_REQUIRE_AUTH=false，方便你直接调试。
# 如果要接近生产环境，建议改成 true，并配置 token。
#
# 支持两种 token 方式：
# 1. 简单 token：
#    - ADMIN_TOKEN：拥有 admin/memory/audit/sensitive 权限。
#    - READER_TOKEN：只能查询普通 memory。
#    - AUDITOR_TOKEN：可以查询 memory + audit。
#
# 2. JSON token map：
#    token -> actor/roles/tenant/workspace/project/user。
#    适合多租户、多项目隔离。
#
# roles:
# - memory_reader：能查 memory。
# - audit_reader：能查 audit / why / usage / lineage / telemetry。
# - sensitive_reader：能直接 include_sensitive=true。
# - admin：拥有所有权限。
#
# include_sensitive=true 还可以通过 X-Memory-Sensitive-Approval 传审批 token。
# 生产环境应接真实审批系统；这里先保留一个本地可用入口。
#
# BEGINNER_AGENT_MEMORY_API_REQUIRE_AUTH=false
# BEGINNER_AGENT_MEMORY_API_ADMIN_TOKEN=
# BEGINNER_AGENT_MEMORY_API_READER_TOKEN=
# BEGINNER_AGENT_MEMORY_API_AUDITOR_TOKEN=
# BEGINNER_AGENT_MEMORY_API_TOKENS={"reader-token":{"actor_id":"reader-1","roles":["memory_reader"],"tenant_id":"local-tenant","workspace_id":"local-workspace","project_id":"beginner_agent","user_id":"local-user"}}
# BEGINNER_AGENT_MEMORY_API_SENSITIVE_APPROVAL_TOKEN=
# BEGINNER_AGENT_MEMORY_API_RATE_LIMIT_ENABLED=true
# BEGINNER_AGENT_MEMORY_API_RATE_LIMIT_PER_MINUTE=120

# Privacy Governance
#
# 中文注释：
# 隐私治理会扫描 secret / PII。
# 原始敏感值不会写入 memory；系统只保存 redacted 文本和 fingerprint。
# fingerprint 使用 salt 生成。
# 本地可以用默认值，团队环境应该换成私有随机值。
#
# BEGINNER_AGENT_PRIVACY_HASH_SALT=change-me-in-shared-environments

# Memory Compaction
#
# 中文注释：
# 长时间运行后 memory 会越来越多。
# Compaction 会把相似经验、失败模式、文件记忆、项目阶段记忆
# 合并成更少的长期记忆。
# 这样可以减少检索噪声，提高 Memory Retriever 的速度和上下文质量。
#
# BEGINNER_AGENT_MEMORY_COMPACTION_ENABLED=true
# BEGINNER_AGENT_MEMORY_COMPACTION_MIN_GROUP_SIZE=4
# BEGINNER_AGENT_MEMORY_COMPACTION_MAX_GROUPS_PER_RUN=3
# BEGINNER_AGENT_MEMORY_COMPACTION_SOURCE_LIMIT=200

# Memory Lifecycle Job
#
# 中文注释：
# 这是定期后台维护任务，不是每次 agent 推理都要运行。
# 它负责：
# - 清理 expired memory。
# - 降权低价值 memory。
# - 提升高价值 memory。
# - 检查 contradiction_key。
# - 生成 summary memory。
# - 按需重建 embedding。
#
# 本地运行：
#
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py --force
#
# BEGINNER_AGENT_MEMORY_LIFECYCLE_SOURCE_LIMIT=300
# BEGINNER_AGENT_MEMORY_LIFECYCLE_SUMMARY_MIN_GROUP_SIZE=6
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RUN_COMPACTION=true
# BEGINNER_AGENT_MEMORY_LIFECYCLE_REBUILD_EMBEDDINGS=true
# BEGINNER_AGENT_MEMORY_LIFECYCLE_EMBEDDING_REBUILD_LIMIT=50
#
# Memory Lifecycle Scheduler
#
# 中文注释：
# lifecycle job 现在不只是“执行一次函数”，而是通过 scheduler 包一层治理：
# - cron 配置：记录这类后台任务应该按什么节奏触发。
# - 任务锁：防止同一时间多个进程同时清理/压缩 memory。
# - 幂等运行记录：同一个 run_key 成功后不会重复执行。
# - 失败重试：失败时按 max_attempts + backoff 重试。
# - 运行历史表：Postgres 会写 beginner_agent_memory_lifecycle_runs。
# - 分布式并发保护：Postgres backend 使用 advisory lock。
#
# 生产环境通常把下面命令放到 cron / Kubernetes CronJob / Prefect / Airflow：
#
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py
#
# BEGINNER_AGENT_MEMORY_LIFECYCLE_CRON=*/30 * * * *
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RUN_KEY=
# BEGINNER_AGENT_MEMORY_LIFECYCLE_HISTORY_BACKEND=auto
# BEGINNER_AGENT_MEMORY_LIFECYCLE_MAX_ATTEMPTS=3
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RETRY_BACKOFF_SECONDS=2.0
# BEGINNER_AGENT_MEMORY_LIFECYCLE_LOCK_TTL_SECONDS=900

# Test suite
#
# 中文注释：
# 默认 pytest 只跑不依赖外部服务的测试。
# Postgres integration test 需要显式打开，避免普通测试因为本地 Docker 未启动失败。
#
# 普通测试：
#   PYTHONPATH=.. uv run --with pytest pytest -q
#
# Postgres 测试：
#   BEGINNER_AGENT_RUN_POSTGRES_TESTS=true \
#   DATABASE_URL=postgresql://beginner_agent:beginner_agent@127.0.0.1:55432/beginner_agent \
#   PYTHONPATH=.. uv run --with pytest pytest -q -m postgres
#
# BEGINNER_AGENT_RUN_POSTGRES_TESTS=false

# Memory access control
#
# 中文注释：
# 这些字段用于隔离不同租户、工作区、项目和用户的记忆。
# 本地单人项目可以使用默认值。
# 如果后续做多项目/多人使用，要给每个运行环境配置不同值。
#
# BEGINNER_AGENT_TENANT_ID=local-tenant
# BEGINNER_AGENT_WORKSPACE_ID=local-workspace
# BEGINNER_AGENT_PROJECT_ID=beginner_agent
# BEGINNER_AGENT_USER_ID=local-user

# Runtime isolation
#
# 中文注释：
# Executor 不直接决定 Python/Rust 怎么运行。
# 真正运行测试、lint、build 的环境在 tooling/runtime.py 里配置。
# 这里可以覆盖 runtime cache 目录，避免写入用户全局目录。
#
# BEGINNER_AGENT_UV_CACHE_DIR=.agent_state/uv-cache
# BEGINNER_AGENT_CARGO_HOME=.agent_state/cargo-home
# BEGINNER_AGENT_CARGO_TARGET_DIR=.agent_state/cargo-target

# Approval workflow
#
# 中文注释：
# Approval Interrupt 会把待审批请求写入本地 SQLite。
# CLI 可以直接审批，也可以启动本地 HTTP API 让 Web/UI/脚本审批。
#
# BEGINNER_AGENT_APPROVAL_DB_PATH=.agent_state/approvals.sqlite3
# BEGINNER_AGENT_APPROVER_ID=local-cli-user
# BEGINNER_AGENT_APPROVAL_TIMEOUT_SECONDS=300
# BEGINNER_AGENT_APPROVAL_API_HOST=127.0.0.1
# BEGINNER_AGENT_APPROVAL_API_PORT=8765

# Production-style runtime nodes
#
# 中文注释：
# 这些配置对应 graph.py 里的 Artifact Collector / Sandbox Runner /
# Async Job Waiter / Observability Reporter。
#
# 当前默认都是本地可运行实现：
# - artifact 写入本地文件系统。
# - observability 写入本地 SQLite。
# - async job 使用本地 SQLite job contract。
# - sandbox 使用 local_controlled，也就是受控工具层。
#
# BEGINNER_AGENT_ARTIFACT_DIR=.agent_state/artifacts
# BEGINNER_AGENT_OBSERVABILITY_DB_PATH=.agent_state/observability.sqlite3
# BEGINNER_AGENT_ASYNC_JOB_DB_PATH=.agent_state/async_jobs.sqlite3
# BEGINNER_AGENT_ASYNC_JOB_TIMEOUT_SECONDS=300
# BEGINNER_AGENT_ASYNC_JOB_POLL_SECONDS=1.0
# BEGINNER_AGENT_SANDBOX_MODE=local_controlled

# Router / Classifier governance
#
# 中文注释：
# Router 是 agent 的第一层分流和风险判断。
# 这些配置用于更接近生产级治理：
# - observability：记录每次 Router 决策，方便审计和排查。
# - rules path：用 JSON 文件覆盖关键词规则，避免所有规则写死在代码里。
# - eval cases：保存 Router 离线评估样本，用于后续回放分类质量。
#
# BEGINNER_AGENT_ROUTER_OBSERVABILITY_ENABLED=true
# BEGINNER_AGENT_MAX_ROUTER_EVENTS=2000
# BEGINNER_AGENT_MAX_ROUTER_EVAL_CASES=1000
# BEGINNER_AGENT_ROUTER_RULES_PATH=.agent_state/router/rules.json

# Only use this when your local OMLX exposes /v1/embeddings
# and Qwen3-Embedding-8B has finished downloading.
#
# 中文注释：
# Qwen3-Embedding-8B 原生可以输出更高维向量。
# 但是当前 beginner_agent 推荐先用 1024 维：
# - 检索质量已经足够学习和本地 code agent 使用。
# - pgvector 索引更容易管理。
# - 写入和查询速度更快。
#
# BEGINNER_AGENT_EMBEDDING_PROVIDER=omlx
# BEGINNER_AGENT_EMBEDDING_DIM=1024
# OMLX_BASE_URL=http://127.0.0.1:8000/v1
# OMLX_API_KEY=local-omlx-key
# OMLX_EMBEDDING_MODEL=Qwen3-Embedding-8B-4bit-DWQ
# OMLX_EMBEDDING_SEND_DIMENSIONS=true
