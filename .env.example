BEGINNER_AGENT_MEMORY_BACKEND=postgres
DATABASE_URL=postgresql://beginner_agent:beginner_agent@127.0.0.1:55432/beginner_agent
BEGINNER_AGENT_CHECKPOINT_BACKEND=postgres
# Optional: use a different database for LangGraph checkpoint.
# If empty, checkpointing.py reuses DATABASE_URL.
#
# BEGINNER_AGENT_CHECKPOINT_DATABASE_URL=<postgres checkpoint database url>
# 中文注释：
# Checkpoint 工程化配置。
#
# BEGINNER_AGENT_CHECKPOINT_ALLOW_MEMORY_FALLBACK：
# - false：生产推荐。Postgres 配置错误时直接失败，避免长任务悄悄丢恢复能力。
# - true：本地开发可用。数据库没启动时降级到 memory checkpoint。
#
# BEGINNER_AGENT_CHECKPOINT_REQUIRE_THREAD_ID：
# - true：生产推荐。恢复长任务必须有稳定 thread_id。
#
# BEGINNER_AGENT_CHECKPOINT_HEALTHCHECK_ENABLED：
# - true：检查 Postgres 连接和 checkpoint 表状态。
# - false：只做配置层检查，不连接数据库。
#
# BEGINNER_AGENT_CHECKPOINT_NAMESPACE：
# - 用于报告和观测里区分 checkpoint 所属 agent / 环境。
#
# BEGINNER_AGENT_CHECKPOINT_ALLOW_MEMORY_FALLBACK=false
# BEGINNER_AGENT_CHECKPOINT_REQUIRE_THREAD_ID=true
# BEGINNER_AGENT_CHECKPOINT_HEALTHCHECK_ENABLED=true
# BEGINNER_AGENT_CHECKPOINT_NAMESPACE=beginner_agent
BEGINNER_AGENT_EMBEDDING_PROVIDER=omlx
BEGINNER_AGENT_EMBEDDING_DIM=1024
OMLX_BASE_URL=http://127.0.0.1:8000/v1
OMLX_API_KEY=local-omlx-key
OMLX_EMBEDDING_MODEL=Qwen3-Embedding-8B-4bit-DWQ
OMLX_EMBEDDING_SEND_DIMENSIONS=true
# Memory governance
#
# 中文注释：
# ttl 类型记忆默认保留多少天。
# pinned / long_term 记忆不会使用这个 TTL。
#
# BEGINNER_AGENT_MEMORY_TTL_DAYS=30

# Memory Postgres migrations
#
# 中文注释：
# Postgres memory schema 现在由 memory_migrations.py 统一管理。
# 它提供：
# - schema version：知道数据库当前到哪个版本。
# - migration files/code：每次建表、加列、建索引都有版本。
# - rollback migration：可以回滚到指定版本。
# - index migration：索引变更不再散落在业务代码里。
# - backfill job：历史数据补齐默认治理字段。
#
# 本地开发默认允许 Store 自动 upgrade，方便你直接运行 agent。
# 生产环境通常设置为 false，由 CI/CD 或运维脚本显式执行 upgrade。
#
# 常用命令：
#
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py status
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py upgrade
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py backfill --limit 1000
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py rollback --target-version 3
#   PYTHONPATH=.. uv run python scripts/manage_memory_migrations.py governance
#
# BEGINNER_AGENT_MEMORY_MIGRATION_AUTO_UPGRADE=true

# Memory quality / reranker governance
#
# 中文注释：
# 默认使用本地规则评分，保证离线可运行、结果可复现。
# 如果要更接近生产级，可以逐步打开：
# - LLM judge：让模型对 memory 质量做第二意见。
# - cross-encoder：让专用 reranker 模型判断 query-memory 是否匹配。
# - A/B bucket：比较 control / candidate reranker 表现。
#
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_ENABLED=false
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_BASE_URL=http://127.0.0.1:8000/v1
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_API_KEY=local-omlx-key
# BEGINNER_AGENT_MEMORY_LLM_JUDGE_MODEL=Qwen3.6-27B-bf16
# BEGINNER_AGENT_MEMORY_CROSS_ENCODER_URL=
# BEGINNER_AGENT_MEMORY_RERANK_BUCKET=

# Memory usage / online eval / observability
#
# 中文注释：
# 这几项对应“Memory 是否真的帮到了任务”的生产闭环：
# - usage effectiveness：记录某条 memory 被用了之后，本轮任务是 helped/neutral/hurt。
# - online eval：真实检索时顺手对照 eval case，持续看命中率。
# - observability sink：把 memory 事件写到可插拔 sink。
#
# 当前支持的 sink：
# - jsonl：本地 JSONL，最适合开发和测试。
# - kafka_spool：先写本地 spool，后续由 Kafka producer / sidecar 发送。
# - otel_spool：先写本地 OTel 风格 spool，后续由 collector 采集。
# - null：关闭观测。
#
# 生产环境一般接 Kafka / OpenTelemetry / 日志平台；
# 这里先把接口和事件模型固定下来，避免 Memory 主路径依赖具体厂商组件。
#
# BEGINNER_AGENT_MEMORY_OBSERVABILITY_ENABLED=true
# BEGINNER_AGENT_MEMORY_OBSERVABILITY_SINK=jsonl
# BEGINNER_AGENT_MEMORY_KAFKA_TOPIC=beginner_agent.memory_events
# BEGINNER_AGENT_MEMORY_OTEL_EXPORTER=local-spool

# Memory Query API
#
# 中文注释：
# 这是只读 Admin API，用来查询 memory、audit、failure pattern、pinned memory 等。
# 推荐用下面的命令启动：
#
#   PYTHONPATH=.. uv run uvicorn beginner_agent.memory_api.app:app --host 127.0.0.1 --port 8770
#
# BEGINNER_AGENT_MEMORY_API_HOST=127.0.0.1
# BEGINNER_AGENT_MEMORY_API_PORT=8770
# BEGINNER_AGENT_MEMORY_API_ACTOR_ID=local-admin
#
# Memory API auth / RBAC / rate limit
#
# 中文注释：
# 本地默认 BEGINNER_AGENT_MEMORY_API_REQUIRE_AUTH=false，方便你直接调试。
# 如果要接近生产环境，建议改成 true，并配置 token。
#
# 支持两种 token 方式：
# 1. 简单 token：
#    - ADMIN_TOKEN：拥有 admin/memory/audit/sensitive 权限。
#    - READER_TOKEN：只能查询普通 memory。
#    - AUDITOR_TOKEN：可以查询 memory + audit。
#
# 2. JSON token map：
#    token -> actor/roles/tenant/workspace/project/user。
#    适合多租户、多项目隔离。
#
# roles:
# - memory_reader：能查 memory。
# - audit_reader：能查 audit / why / usage / lineage / telemetry。
# - sensitive_reader：能直接 include_sensitive=true。
# - admin：拥有所有权限。
#
# include_sensitive=true 还可以通过 X-Memory-Sensitive-Approval 传审批 token。
# 生产环境应接真实审批系统；这里先保留一个本地可用入口。
#
# BEGINNER_AGENT_MEMORY_API_REQUIRE_AUTH=false
# BEGINNER_AGENT_MEMORY_API_ADMIN_TOKEN=
# BEGINNER_AGENT_MEMORY_API_READER_TOKEN=
# BEGINNER_AGENT_MEMORY_API_AUDITOR_TOKEN=
# BEGINNER_AGENT_MEMORY_API_TOKENS={"reader-token":{"actor_id":"reader-1","roles":["memory_reader"],"tenant_id":"local-tenant","workspace_id":"local-workspace","project_id":"beginner_agent","user_id":"local-user"}}
# BEGINNER_AGENT_MEMORY_API_SENSITIVE_APPROVAL_TOKEN=
# BEGINNER_AGENT_MEMORY_API_RATE_LIMIT_ENABLED=true
# BEGINNER_AGENT_MEMORY_API_RATE_LIMIT_PER_MINUTE=120

# Privacy Governance
#
# 中文注释：
# 隐私治理会扫描 secret / PII。
# 原始敏感值不会写入 memory；系统只保存 redacted 文本和 fingerprint。
# fingerprint 使用 salt 生成。
# 本地可以用默认值，团队环境应该换成私有随机值。
#
# BEGINNER_AGENT_PRIVACY_HASH_SALT=change-me-in-shared-environments

# Memory Compaction
#
# 中文注释：
# 长时间运行后 memory 会越来越多。
# Compaction 会把相似经验、失败模式、文件记忆、项目阶段记忆
# 合并成更少的长期记忆。
# 这样可以减少检索噪声，提高 Memory Retriever 的速度和上下文质量。
#
# BEGINNER_AGENT_MEMORY_COMPACTION_ENABLED=true
# BEGINNER_AGENT_MEMORY_COMPACTION_MIN_GROUP_SIZE=4
# BEGINNER_AGENT_MEMORY_COMPACTION_MAX_GROUPS_PER_RUN=3
# BEGINNER_AGENT_MEMORY_COMPACTION_SOURCE_LIMIT=200

# Memory Lifecycle Job
#
# 中文注释：
# 这是定期后台维护任务，不是每次 agent 推理都要运行。
# 它负责：
# - 清理 expired memory。
# - 降权低价值 memory。
# - 提升高价值 memory。
# - 检查 contradiction_key。
# - 生成 summary memory。
# - 按需重建 embedding。
#
# 本地运行：
#
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py --force
#
# BEGINNER_AGENT_MEMORY_LIFECYCLE_SOURCE_LIMIT=300
# BEGINNER_AGENT_MEMORY_LIFECYCLE_SUMMARY_MIN_GROUP_SIZE=6
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RUN_COMPACTION=true
# BEGINNER_AGENT_MEMORY_LIFECYCLE_REBUILD_EMBEDDINGS=true
# BEGINNER_AGENT_MEMORY_LIFECYCLE_EMBEDDING_REBUILD_LIMIT=50
#
# Memory Lifecycle Scheduler
#
# 中文注释：
# lifecycle job 现在不只是“执行一次函数”，而是通过 scheduler 包一层治理：
# - cron 配置：记录这类后台任务应该按什么节奏触发。
# - 任务锁：防止同一时间多个进程同时清理/压缩 memory。
# - 幂等运行记录：同一个 run_key 成功后不会重复执行。
# - 失败重试：失败时按 max_attempts + backoff 重试。
# - 运行历史表：Postgres 会写 beginner_agent_memory_lifecycle_runs。
# - 分布式并发保护：Postgres backend 使用 advisory lock。
#
# 生产环境通常把下面命令放到 cron / Kubernetes CronJob / Prefect / Airflow：
#
#   PYTHONPATH=.. uv run python scripts/run_memory_lifecycle.py
#
# BEGINNER_AGENT_MEMORY_LIFECYCLE_CRON=*/30 * * * *
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RUN_KEY=
# BEGINNER_AGENT_MEMORY_LIFECYCLE_HISTORY_BACKEND=auto
# BEGINNER_AGENT_MEMORY_LIFECYCLE_MAX_ATTEMPTS=3
# BEGINNER_AGENT_MEMORY_LIFECYCLE_RETRY_BACKOFF_SECONDS=2.0
# BEGINNER_AGENT_MEMORY_LIFECYCLE_LOCK_TTL_SECONDS=900

# Test suite
#
# 中文注释：
# 默认 pytest 只跑不依赖外部服务的测试。
# Postgres integration test 需要显式打开，避免普通测试因为本地 Docker 未启动失败。
#
# 普通测试：
#   PYTHONPATH=.. uv run --with pytest pytest -q
#
# Postgres 测试：
#   BEGINNER_AGENT_RUN_POSTGRES_TESTS=true \
#   DATABASE_URL=postgresql://beginner_agent:beginner_agent@127.0.0.1:55432/beginner_agent \
#   PYTHONPATH=.. uv run --with pytest pytest -q -m postgres
#
# BEGINNER_AGENT_RUN_POSTGRES_TESTS=false

# Router governance
#
# 中文注释：
# Router 现在是多阶段结构：
# - Intent Router：判断用户想做什么。
# - Risk Router：判断风险等级。
# - Tool Needs Router：判断是否需要工具。
# - Security Router：本地安全分类，保守提升风险。
#
# 下面三个配置控制每个 LLM 子 Router 的输出 token 预算。
# 如果不设置，默认复用 prompt registry 里的 max_tokens。
# 后续要做到“每个阶段使用不同模型”，也应该继续放在 env/config，
# 不要写死在 routering/nodes.py 里。
#
# BEGINNER_AGENT_ROUTER_INTENT_MAX_TOKENS=80
# BEGINNER_AGENT_ROUTER_RISK_MAX_TOKENS=80
# BEGINNER_AGENT_ROUTER_TOOL_NEEDS_MAX_TOKENS=80
# BEGINNER_AGENT_ROUTER_SECURITY_CLASSIFIER_MAX_TOKENS=120
# BEGINNER_AGENT_ROUTER_REPAIR_MAX_TOKENS=120
#
# 中文注释：
# 多模型 Router：
# 可以为每个子 Router 指定不同模型。
# 如果不配置，默认使用 llm_client.py 的 OMLX_MODEL。
#
# BEGINNER_AGENT_ROUTER_MODEL=
# BEGINNER_AGENT_ROUTER_CHEAP_MODEL=
# BEGINNER_AGENT_ROUTER_STRONG_MODEL=
# BEGINNER_AGENT_ROUTER_INTENT_MODEL=
# BEGINNER_AGENT_ROUTER_RISK_MODEL=
# BEGINNER_AGENT_ROUTER_TOOL_NEEDS_MODEL=
# BEGINNER_AGENT_ROUTER_SECURITY_CLASSIFIER_MODEL=
# BEGINNER_AGENT_ROUTER_REPAIR_MODEL=
#
# 中文注释：
# 多模型升级策略：
# - primary_model_tier=cheap 时，Router 先用便宜模型。
# - confidence 低于阈值时，升级 strong model 复判。
# - risk=high 时，可以强制 strong model 复判，但最终会保守保留 high。
#
# BEGINNER_AGENT_ROUTER_PRIMARY_MODEL_TIER=primary
# BEGINNER_AGENT_ROUTER_MODEL_ESCALATION_ENABLED=false
# BEGINNER_AGENT_ROUTER_STRONG_CONFIDENCE_THRESHOLD=0.70
# BEGINNER_AGENT_ROUTER_HIGH_RISK_STRONG_VALIDATION_ENABLED=true
#
# 中文注释：
# 阶段预算：
# 当前实现会把预算写入 RouterEvent，方便观测和复核。
# 同时，下面这些 *_TIMEOUT_MS 会被传入 LLM HTTP 请求，作为真实硬超时。
# 如果某个 Router 子阶段超时，该阶段会进入 fallback，不会卡住整个 agent。
# BEGINNER_AGENT_ROUTER_MAX_TOTAL_LATENCY_MS 用于总耗时复核/告警，不直接杀掉流程。
#
# BEGINNER_AGENT_ROUTER_INTENT_TIMEOUT_MS=1000
# BEGINNER_AGENT_ROUTER_RISK_TIMEOUT_MS=1000
# BEGINNER_AGENT_ROUTER_TOOL_NEEDS_TIMEOUT_MS=1000
# BEGINNER_AGENT_ROUTER_SECURITY_CLASSIFIER_TIMEOUT_MS=1000
# BEGINNER_AGENT_ROUTER_REPAIR_TIMEOUT_MS=1000
# BEGINNER_AGENT_ROUTER_MAX_TOTAL_LATENCY_MS=3000
#
# 中文注释：
# LLM Security Classifier：
# - 默认关闭，避免每次 Router 都多一次模型调用。
# - 打开后，它只允许提高风险或补充安全标签，不能降低本地规则/正则的判断。
# - 输入会先经过 secret / PII 脱敏。
#
# BEGINNER_AGENT_ROUTER_SECURITY_CLASSIFIER_ENABLED=false
#
# Router failure policy
#
# 中文注释：
# Router 现在不是“模型输出错就立刻失败/兜底”。
# 更接近生产级的路径是：
#
#   LLM -> validate
#     -> repair retry
#     -> stage-aware fallback
#     -> conservative risk/security policy
#     -> structured failure audit
#
# repair retry 只修 JSON 格式，不允许改变语义。
# risk/security 失败时默认保守升级，避免不确定时放行危险操作。
#
# BEGINNER_AGENT_ROUTER_REPAIR_RETRY_ENABLED=true
# BEGINNER_AGENT_ROUTER_MAX_REPAIR_ATTEMPTS=1
# BEGINNER_AGENT_ROUTER_RISK_FAILURE_POLICY=conservative
# BEGINNER_AGENT_ROUTER_SECURITY_FAILURE_POLICY=raise_risk
# BEGINNER_AGENT_ROUTER_LOW_CONFIDENCE_POLICY=fallback
#
# Router human feedback loop
#
# 中文注释：
# 当你发现某次 Router 分错了，可以把这次真实 router_report
# 或 decision_id 提交成纠错反馈。
# 系统会同时保存：
# - router_feedback.jsonl：谁纠正了哪次错误。
# - router_eval_cases.jsonl：后续 replay 会自动覆盖这个案例。
#
# 示例：
#
#   PYTHONPATH=.. uv run python scripts/router_eval.py feedback \
#     --decision-id <router decision id> \
#     --task-type agent \
#     --risk-level high \
#     --needs-tool true \
#     --reason "代码修改应该进入 agent 高风险分支"
#
# BEGINNER_AGENT_ROUTER_FEEDBACK_ACTOR_ID=local-user
#
# Router conflict / metrics / review / regression gate
#
# 中文注释：
# Router 会记录：
# - conflicts：LLM / rules / security / context policy 是否冲突。
# - metrics：本地聚合 request_total、fallback_total、latency 等指标。
# - review queue：高风险、低置信度、冲突、repair、security override 进入人工复核队列。
# - regression gate：eval replay 后按阈值判断是否允许启用当前 Router 配置。
#
# BEGINNER_AGENT_ROUTER_REVIEW_QUEUE_ENABLED=true
# BEGINNER_AGENT_ROUTER_REVIEW_CONFIDENCE=0.5
# BEGINNER_AGENT_ROUTER_GATE_MIN_PASS_RATE=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_TASK_TYPE_ACCURACY=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_RISK_LEVEL_ACCURACY=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_NEEDS_TOOL_ACCURACY=0.90

# Memory access control
#
# 中文注释：
# 这些字段用于隔离不同租户、工作区、项目和用户的记忆。
# 本地单人项目可以使用默认值。
# 如果后续做多项目/多人使用，要给每个运行环境配置不同值。
#
# BEGINNER_AGENT_TENANT_ID=local-tenant
# BEGINNER_AGENT_WORKSPACE_ID=local-workspace
# BEGINNER_AGENT_PROJECT_ID=beginner_agent
# BEGINNER_AGENT_USER_ID=local-user

# Runtime isolation
#
# 中文注释：
# Executor 不直接决定 Python/Rust 怎么运行。
# 真正运行测试、lint、build 的环境在 tooling/runtime.py 里配置。
# 这里可以覆盖 runtime cache 目录，避免写入用户全局目录。
#
# BEGINNER_AGENT_UV_CACHE_DIR=.agent_state/uv-cache
# BEGINNER_AGENT_CARGO_HOME=.agent_state/cargo-home
# BEGINNER_AGENT_CARGO_TARGET_DIR=.agent_state/cargo-target

# Approval workflow
#
# 中文注释：
# Approval Interrupt 会把待审批请求写入本地 SQLite。
# CLI 可以直接审批，也可以启动本地 HTTP API 让 Web/UI/脚本审批。
#
# BEGINNER_AGENT_APPROVAL_DB_PATH=.agent_state/approvals.sqlite3
# BEGINNER_AGENT_APPROVER_ID=local-cli-user
# BEGINNER_AGENT_APPROVAL_TIMEOUT_SECONDS=300
# BEGINNER_AGENT_APPROVAL_API_HOST=127.0.0.1
# BEGINNER_AGENT_APPROVAL_API_PORT=8765

# Production-style runtime nodes
#
# 中文注释：
# 这些配置对应 graph.py 里的 Artifact Collector / Sandbox Runner /
# Async Job Waiter / Observability Reporter。
#
# 当前默认都是本地可运行实现：
# - artifact 写入本地文件系统。
# - observability 写入本地 SQLite。
# - async job 使用本地 SQLite job contract。
# - sandbox 使用 local_controlled，也就是受控工具层。
#
# BEGINNER_AGENT_ARTIFACT_DIR=.agent_state/artifacts
# BEGINNER_AGENT_OBSERVABILITY_DB_PATH=.agent_state/observability.sqlite3
# BEGINNER_AGENT_ASYNC_JOB_DB_PATH=.agent_state/async_jobs.sqlite3
# BEGINNER_AGENT_ASYNC_JOB_TIMEOUT_SECONDS=300
# BEGINNER_AGENT_ASYNC_JOB_POLL_SECONDS=1.0
# BEGINNER_AGENT_SANDBOX_MODE=local_controlled

# Router / Classifier governance
#
# 中文注释：
# Router 是 agent 的第一层分流和风险判断。
# 这些配置用于更接近生产级治理：
# - observability：记录每次 Router 决策，方便审计和排查。
# - rules path：用 JSON 文件覆盖关键词规则，避免所有规则写死在代码里。
# - eval cases：保存 Router 离线评估样本，用于后续回放分类质量。
#
# BEGINNER_AGENT_ROUTER_OBSERVABILITY_ENABLED=true
# 中文注释：
# Router observability 现在支持可插拔 sink。
# - jsonl：默认，写入 .agent_state/router/router_events.jsonl。
# - null：不写事件，适合临时关闭观测。
# - kafka_spool：先写本地 spool 文件，后续由 producer/sidecar 转发到 Kafka。
#
# BEGINNER_AGENT_ROUTER_OBSERVABILITY_SINK=jsonl
# BEGINNER_AGENT_MAX_ROUTER_EVENTS=2000
# BEGINNER_AGENT_MAX_ROUTER_EVAL_CASES=1000
# BEGINNER_AGENT_MAX_ROUTER_EVAL_TRENDS=500
# BEGINNER_AGENT_ROUTER_KAFKA_TOPIC=beginner_agent.router_events
# BEGINNER_AGENT_ROUTER_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
# 中文注释：
# Router eval 支持批量 replay、趋势记录和线上反馈回流。
#
# 常用命令：
#
#   PYTHONPATH=.. uv run python scripts/router_eval.py replay
#   PYTHONPATH=.. uv run python scripts/router_eval.py replay --dataset router_eval.json
#   PYTHONPATH=.. uv run python scripts/router_eval.py gate --dataset router_eval.json
#   PYTHONPATH=.. uv run python scripts/router_eval.py write-baseline --dataset router_eval.json
#   PYTHONPATH=.. uv run python scripts/router_release_gate.py --dataset router_eval.json
#   PYTHONPATH=.. uv run python scripts/router_eval.py feedback --user-input "帮我修复测试" \
#       --task-type agent --risk-level high --needs-tool true --reason "代码修改必须进 agent"
#   PYTHONPATH=.. uv run python scripts/router_eval.py trends --limit 10
#
# BEGINNER_AGENT_ROUTER_EVAL_DATASET_PATH=.agent_state/router/router_eval_dataset.json
# 中文注释：
# 如果不设置 BEGINNER_AGENT_ROUTER_EVAL_DATASET_PATH，
# Router eval 会先读取线上反馈沉淀的 eval cases；
# 如果本地还没有反馈样本，则使用项目内置的分层核心数据集：
# router_eval_datasets/router_eval_core.json
# BEGINNER_AGENT_ROUTER_EVAL_DATASET_VERSION=router-eval-local-v1
# BEGINNER_AGENT_ROUTER_EVAL_BASELINE_PATH=.agent_state/router/router_eval_baseline.json
# BEGINNER_AGENT_ROUTER_VERSION=router-local
#
# 中文注释：
# Router release gate：
# - MIN_* 是绝对阈值，低于它就阻止启用。
# - MAX_*_DROP 是相对 baseline 的最大允许下降幅度。
# - gate 命令返回非 0 退出码时，适合让 CI/pre-push 阻止提交或阻止上线。
#
# BEGINNER_AGENT_ROUTER_GATE_MIN_PASS_RATE=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_TASK_TYPE_ACCURACY=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_RISK_LEVEL_ACCURACY=0.90
# BEGINNER_AGENT_ROUTER_GATE_MIN_NEEDS_TOOL_ACCURACY=0.90
# 中文注释：
# Router eval 分层门禁。
# 总体准确率可能掩盖某类能力退化，所以这里可以按 category 设置阈值。
# 默认类别包括：
# normal_chat_cases / code_agent_cases / tool_needed_cases / high_risk_cases /
# prompt_injection_cases / secret_pii_cases / ambiguous_cases / regression_cases
# BEGINNER_AGENT_ROUTER_GATE_MIN_CATEGORY_PASS_RATE=0.80
# BEGINNER_AGENT_ROUTER_GATE_MIN_HIGH_RISK_CASES_PASS_RATE=0.95
# BEGINNER_AGENT_ROUTER_GATE_MIN_PROMPT_INJECTION_CASES_PASS_RATE=0.95
# BEGINNER_AGENT_ROUTER_GATE_MIN_SECRET_PII_CASES_PASS_RATE=0.95
# BEGINNER_AGENT_ROUTER_GATE_MAX_PASS_RATE_DROP=0.02
# BEGINNER_AGENT_ROUTER_GATE_MAX_TASK_TYPE_ACCURACY_DROP=0.02
# BEGINNER_AGENT_ROUTER_GATE_MAX_RISK_LEVEL_ACCURACY_DROP=0.02
# BEGINNER_AGENT_ROUTER_GATE_MAX_NEEDS_TOOL_ACCURACY_DROP=0.02
# BEGINNER_AGENT_ROUTER_GATE_MAX_CATEGORY_PASS_RATE_DROP=0.05
#
# Router prompt registry
#
# 中文注释：
# Router config registry 是更统一的配置中心入口。
# 当前用本地 JSON manifest 模拟，后续可以替换成远程配置服务。
#
# BEGINNER_AGENT_ROUTER_CONFIG_REGISTRY_PATH=.agent_state/router/config_registry.json
#
# manifest 示例：
#
# {
#   "version": "router-config-registry-2026-07-23",
#   "artifacts": [
#     {
#       "id": "prompt.active",
#       "type": "prompt",
#       "version": "router-prompt-2026-07-23",
#       "status": "active",
#       "path": ".agent_state/router/router_prompt.json",
#       "rollout_percent": 100,
#       "experiment_group": "control"
#     },
#     {
#       "id": "models.active",
#       "type": "model_strategy",
#       "version": "router-models-2026-07-23",
#       "status": "active",
#       "env": {
#         "BEGINNER_AGENT_ROUTER_PRIMARY_MODEL_TIER": "cheap",
#         "BEGINNER_AGENT_ROUTER_CHEAP_MODEL": "cheap-router",
#         "BEGINNER_AGENT_ROUTER_STRONG_MODEL": "strong-router"
#       }
#     }
#   ]
# }
#
# 中文注释：
# Router prompt 不再建议写死在 routering/nodes.py 里。
# 生产级通常把 prompt 当成可治理资产：
# - version：当前 prompt 版本。
# - experiment_group：实验组。
# - rollout_percent：灰度比例。
# - rollback path：新 prompt 出问题时回滚。
#
# prompt registry 文件示例：
#
# {
#   "version": "router-prompt-2026-07-22",
#   "experiment_group": "control",
#   "template": "你是 agent 的 Router / Classifier。请只返回严格 JSON...",
#   "temperature": 0,
#   "max_tokens": 240,
#   "variants": [
#     {
#       "version": "router-prompt-2026-07-22-candidate",
#       "experiment_group": "candidate",
#       "rollout_percent": 10,
#       "template": "候选 Router prompt..."
#     }
#   ]
# }
#
# BEGINNER_AGENT_ROUTER_PROMPT_PATH=.agent_state/router/router_prompt.json
# BEGINNER_AGENT_ROUTER_PROMPT_ROLLBACK_PATH=.agent_state/router/router_prompt.previous.json
# BEGINNER_AGENT_ROUTER_PROMPT_VERSION=router-prompt-builtin-v1
# BEGINNER_AGENT_ROUTER_PROMPT_EXPERIMENT_GROUP=control
# BEGINNER_AGENT_ROUTER_PROMPT_TEMPERATURE=0
# BEGINNER_AGENT_ROUTER_PROMPT_MAX_TOKENS=240
# BEGINNER_AGENT_ROUTER_RULES_PATH=.agent_state/router/rules.json
# 中文注释：
# Router rules 现在支持 RuleSpec 风格配置：
#
# {
#   "version": "router-rules-2026-07-22",
#   "rules": [
#     {
#       "id": "task.agent.code_review",
#       "category": "task_type",
#       "outcome": "agent",
#       "keywords": ["审计代码", "修复测试"],
#       "priority": 400,
#       "enabled": true,
#       "rollout_percent": 100,
#       "reason": "代码审计/修复应该进入复杂 agent loop。"
#     }
#   ]
# }
#
# 如果新规则有问题，可以把 rollback path 指向上一版规则文件。
# BEGINNER_AGENT_ROUTER_RULES_ROLLBACK_PATH=.agent_state/router/rules.previous.json
# BEGINNER_AGENT_ROUTER_MIN_CONFIDENCE=0.5
# BEGINNER_AGENT_ROUTER_MAX_MODEL_RESPONSE_CHARS=2000
# BEGINNER_AGENT_ROUTER_HIGH_RISK_TENANTS=
# BEGINNER_AGENT_ROUTER_HIGH_RISK_PROJECTS=
# BEGINNER_AGENT_ROUTER_HIGH_RISK_USERS=
#
# Router security classifier
#
# 中文注释：
# Router security 现在不是简单关键词判断，而是分层安全分类：
# - 内置 SecurityPattern policy。
# - secret / PII detector。
# - historical abuse patterns。
# - 结构化 finding：id、severity、confidence、redacted evidence。
#
# 可以通过 JSON 文件覆盖安全策略：
#
# {
#   "version": "security-policy-2026-07-22",
#   "patterns": [
#     {
#       "id": "security.custom.exfiltrate_logs",
#       "kind": "data_exfiltration",
#       "label": "data_exfiltration",
#       "malicious_intent": "data_exfiltration",
#       "injection_risk": "none",
#       "severity": "critical",
#       "confidence": 0.91,
#       "keywords": ["导出全部日志"],
#       "priority": 900,
#       "reason": "导出全部日志可能包含敏感数据。"
#     }
#   ]
# }
#
# BEGINNER_AGENT_ROUTER_SECURITY_POLICY_PATH=.agent_state/router/security_policy.json
# BEGINNER_AGENT_ROUTER_ABUSE_PATTERNS_PATH=.agent_state/router/abuse_patterns.json

# Only use this when your local OMLX exposes /v1/embeddings
# and Qwen3-Embedding-8B has finished downloading.
#
# 中文注释：
# Qwen3-Embedding-8B 原生可以输出更高维向量。
# 但是当前 beginner_agent 推荐先用 1024 维：
# - 检索质量已经足够学习和本地 code agent 使用。
# - pgvector 索引更容易管理。
# - 写入和查询速度更快。
#
# BEGINNER_AGENT_EMBEDDING_PROVIDER=omlx
# BEGINNER_AGENT_EMBEDDING_DIM=1024
# OMLX_BASE_URL=http://127.0.0.1:8000/v1
# OMLX_API_KEY=local-omlx-key
# OMLX_EMBEDDING_MODEL=Qwen3-Embedding-8B-4bit-DWQ
# OMLX_EMBEDDING_SEND_DIMENSIONS=true
